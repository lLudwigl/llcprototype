{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "outDir": "./dist",
    "composite": true,
    "noEmit": false
  },
  "include": ["src"]
}
